# Environment Configuration for Zenkai Client

# Network: 'alfajores' for testnet, 'celo' for mainnet
VITE_NETWORK=alfajores

# Backend server URL (update after deploying server)
VITE_SERVER_URL=https://your-server-url.vercel.app

# WalletConnect Project ID (get from https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here